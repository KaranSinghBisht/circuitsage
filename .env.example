OLLAMA_BASE_URL=http://localhost:11434
# For 8 GB Macs that can't host gemma3:4b locally, swap in a Modal-hosted endpoint:
# OLLAMA_BASE_URL=https://<your-handle>--circuitsage-ollama-serve.modal.run
# (See docs/HOSTED_OLLAMA_MODAL.md for one-shot deploy.)
OLLAMA_MODEL=gemma3:4b
OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text
FRONTEND_ORIGIN=http://localhost:5173
CIRCUITSAGE_DEV=1
